rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: Is the request from the authenticated owner? ───
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── USERS (profiles) ───
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // Users cannot delete their own profile (admin only)
      allow delete: if false;

      // ─── TRANSACTIONS (sub-collection) ───
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.type in ['income', 'expense']
          && request.resource.data.amount > 0;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ─── BUDGETS (sub-collection) ───
      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ─── STREAK HISTORY (sub-collection) ───
      match /streak_history/{date} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        // No updates or deletes — audit trail
        allow update, delete: if false;
      }

      // ─── REDEMPTIONS (sub-collection) ───
      match /redemptions/{redemptionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ─── REWARDS (global, read-only for users) ───
    match /rewards/{rewardId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via Firebase Admin SDK
    }
  }
}
